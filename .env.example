DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
PORT=3001

# For Netlify (serverless) deployments, use Neon's POOLED connection string
# (the one with "-pooler" in the host) and add pgbouncer=true so Prisma
# doesn't use prepared statements that pgbouncer can't handle, e.g.:
# DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
