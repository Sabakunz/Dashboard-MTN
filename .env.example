# Pooled connection (used at runtime). Use connection_limit >= 4-5 so the
# 6 concurrent dashboard requests (kpi/machines/breakdowns/pareto/
# pareto-machines/downtime-by-day) don't starve each other waiting on a
# single pooled connection.
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true&connection_limit=5"

# Direct (non-pooled) connection, used for migrations.
DIRECT_URL="postgresql://user:password@host:5432/dbname"

PORT=3001

# Secret used to sign admin login JWTs - keep this private
JWT_SECRET="change-me-to-a-long-random-string"
